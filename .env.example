# ═══════════════════════════════════════════════════════════════════════
# OpenClaw Mission Control v2 — Configuration
# ═══════════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────────
MC_PORT=3100
MC_HOST=127.0.0.1
NODE_ENV=production

# ─── Authentication (REQUIRED — change both before first run) ─────────
# Generate with: openssl rand -base64 16
MC_ADMIN_PASSWORD=CHANGE_ME_NOW
# Generate with: openssl rand -base64 32
MC_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# ─── Database ──────────────────────────────────────────────────────────
MC_DB_PATH=./data/mission-control.db

# ─── OpenClaw Gateways ────────────────────────────────────────────────
# Comma-separated: id:host:port:token
# IMPORTANT: Each gateway MUST have its bind set to allow cross-network access.
# On each gateway host, run ONE of:
#   openclaw config set gateway.bind '"lan"'           # Bind to LAN IP
#   openclaw config set gateway.auth.mode '"token"'    # Required for non-loopback
#   openclaw config set gateway.auth.token '"your-secret-token"'
#
# Or use SSH tunnels (more secure):
#   ssh -L 18789:127.0.0.1:18789 user@192.168.1.10
#   Then use host=127.0.0.1 in the gateway config below.
#
# Or use Tailscale:
#   openclaw config set gateway.bind '"tailnet"'
#   openclaw config set gateway.auth.allowTailscale true
MC_GATEWAYS=gw-0:192.168.1.10:18789:your-token-here,gw-1:192.168.1.11:18789:your-token-here

# ─── OpenAI (for AI analysis features) ────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── HTTPS / TLS ──────────────────────────────────────────────────────
MC_DOMAIN=mc.local

# ─── Watchdog ──────────────────────────────────────────────────────────
MC_WATCHDOG_ENABLED=true
# Webhook URL called on escalation (receives JSON payload)
# MC_WATCHDOG_WEBHOOK_URL=https://your-monitoring-system.com/webhook
# Slack webhook for escalation alerts
# MC_WATCHDOG_SLACK_URL=https://hooks.slack.com/services/T.../B.../xxx

# ─── Monitoring ────────────────────────────────────────────────────────
MC_HEALTH_POLL_INTERVAL=15000
MC_EVENT_RETENTION_DAYS=30

# ─── Logging ───────────────────────────────────────────────────────────
# Levels: error, warn, info, debug
MC_LOG_LEVEL=info
# Format: text (human-readable) or json (for log aggregators)
MC_LOG_FORMAT=text

# ─── Credential Vault ─────────────────────────────────────────────────
# REQUIRED for production. All credentials are AES-256-GCM encrypted with this key.
# Generate with: openssl rand -hex 32
MC_VAULT_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
# Token for agent API access (agents use this to query infrastructure + checkout credentials)
# Generate with: openssl rand -hex 24
MC_AGENT_TOKEN=CHANGE_ME_GENERATE_AGENT_TOKEN
